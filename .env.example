# ============ COPY THIS FILE TO .env AND FILL IN ============
# All of these are FREE to obtain. See SETUP_GUIDE.md for how.

# --- Google Gemini (free tier) : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Pexels (free) : https://www.pexels.com/api/
PEXELS_API_KEY=

# --- Pixabay (free) : https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# --- YouTube Data API v3 (free) : OAuth client, see SETUP_GUIDE.md
# These are stored as GitHub Secrets, not committed.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Instagram (RUN LOCALLY ONLY — username/password login) ---
IG_USERNAME=
IG_PASSWORD=
